{
  "name": "ghostwriter",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.11.0",
  "scripts": {
    "verify": "pnpm typecheck && pnpm lint && pnpm test",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "test": "node --test .cursor/hooks/enforce-test-model-routing.test.mjs && vitest run --exclude 'e2e/**' --exclude '.cursor/hooks/**' --maxWorkers=2",
    "test:e2e": "playwright test",
    "db:generate": "pnpm --filter @ghostwriter/storage db:generate",
    "db:migrate": "pnpm --filter @ghostwriter/storage db:migrate",
    "lakebase": "./scripts/lakebase.sh"
  },
  "devDependencies": {
    "@eslint/js": "latest",
    "@playwright/test": "^1.61.1",
    "eslint": "latest",
    "typescript": "^5.9.3",
    "typescript-eslint": "latest",
    "vitest": "latest"
  }
}
